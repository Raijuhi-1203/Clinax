<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/bt_addcart">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:orientation="vertical">

            <com.daimajia.slider.library.SliderLayout
                android:id="@+id/pager"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:padding="0dp"
                android:layout_alignParentTop="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <androidx.cardview.widget.CardView
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="8dp" >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="5dp">

                    <ImageView
                        android:layout_marginTop="5dp"
                        android:layout_width="100dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:src="@drawable/consultonline" />

                    <TextView
                        android:textStyle="bold"
                        android:textSize="13dp"
                        android:layout_marginTop="5dp"
                        android:textColor="@color/black"
                        android:textAlignment="center"
                        android:maxLines="1"
                        android:text="Online Consult"
                         android:fontFamily="@font/custom_font"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textColor="@color/black"
                        android:textAlignment="textStart"
                        android:textSize="11dp"
                        android:layout_marginLeft="5dp"
                        android:maxLines="3"
                        android:layout_marginTop="0dp"
                        android:text="Connect and Consult Online with Specialist Doctor 24*7 hours."
                        android:fontFamily="@font/custom_font"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/btconsult"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_gravity="center"
                        android:layout_marginLeft="10dp"
                        android:layout_marginTop="10dp"
                        android:textAllCaps="false"
                        android:layout_marginRight="10dp"
                        android:layout_marginBottom="8dp"
                         android:fontFamily="@font/custom_font"
                        android:background="@drawable/bluebt"
                        android:gravity="center"
                        android:padding="3dp"
                        android:text="Consult Online"
                        android:textAlignment="center"
                        android:textColor="#fff"
                        android:textSize="12dp"
                        android:textStyle="bold" />
                </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_view"
                    android:layout_margin="5dp"
                    android:layout_weight="1"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="8dp" >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="5dp">

                        <ImageView
                            android:layout_marginTop="5dp"
                            android:layout_width="100dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center"
                            android:src="@drawable/bkappoinment" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="Find &amp; Book Appointment"
                            android:textAlignment="center"
                            android:textColor="@color/black"
                            android:textSize="13dp"
                            android:maxLines="1"
                            android:textStyle="bold"
                            android:fontFamily="@font/custom_font" />
                        <TextView
                            android:textColor="@color/black"
                            android:textAlignment="textStart"
                            android:textSize="11dp"
                            android:layout_marginLeft="2dp"
                            android:maxLines="3"
                            android:text="Search your doctor and Book Online Appointment for in-clinic OPD."
                            android:fontFamily="@font/custom_font"
                            android:layout_marginTop="0dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                        <Button
                            android:id="@+id/btappoinment"
                            android:layout_width="match_parent"
                            android:layout_height="35dp"
                            android:layout_gravity="center"
                            android:layout_marginLeft="12dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginRight="10dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/custom_font"
                            android:background="@drawable/bluebt"
                            android:gravity="center"
                            android:padding="3dp"
                            android:textAllCaps="false"
                            android:text="Book Appointment"
                            android:textAlignment="center"
                            android:textColor="#fff"
                            android:textSize="12dp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <TextView
                android:textColor="@color/black"
                android:textStyle="bold"
                 android:fontFamily="@font/custom_font"
                android:textSize="14dp"
                android:layout_margin="5dp"
                android:text="Consult Online For Common Health Problems :-"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <androidx.recyclerview.widget.RecyclerView
                android:orientation="vertical"
                android:scrollbars="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:id="@+id/rvproblem"
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />


            <TextView
                android:id="@+id/bt_consult_healthprblm"
                android:textStyle="bold"
                android:text="View More"
                android:textAlignment="center"
                android:textSize="14dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:fontFamily="@font/custom_font"
                android:layout_marginTop="10dp"
                android:textColor="@color/white"
                android:layout_marginRight="100dp"
                android:layout_marginLeft="100dp"
                android:background="@drawable/bluebt"
                android:layout_width="match_parent"
                android:layout_height="30dp"/>

            <TextView
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_margin="5dp"
                 android:fontFamily="@font/custom_font"
                android:textSize="14dp"
                android:text="Book Appoinment with Top Specialist :-"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvspeciality"
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/bt_view_spcilist"
                android:textColor="@color/white"
                android:layout_marginRight="100dp"
                android:layout_marginLeft="100dp"
                android:textStyle="bold"
                 android:fontFamily="@font/custom_font"
                android:text="View All Specialist"
                android:textAlignment="center"
                android:textSize="14dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/bluebt"
                android:layout_width="match_parent"
                android:layout_height="30dp"/>

        </LinearLayout>

        </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>