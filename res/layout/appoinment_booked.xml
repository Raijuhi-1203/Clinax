<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="18dp"
        android:background="@color/theme_2"
        android:layout_width="match_parent"
        android:layout_height="90dp">

        <TextView
            android:textStyle="bold"
            android:textSize="16dp"
            android:id="@+id/cdt"
            android:fontFamily="@font/custom_font"
            android:text="17 February 2021"
            android:textColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:textStyle="bold"
            android:textSize="16dp"
            android:fontFamily="@font/custom_font"
            android:layout_marginTop="5dp"
            android:text="Clinax"
            android:textColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:padding="18dp"
        android:gravity="center"
        android:background="@color/getinstantconsultbt"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:src="@drawable/check"
            android:layout_width="100dp"
            android:layout_height="100dp"/>

        <TextView
            android:textSize="20dp"
            android:layout_marginTop="5dp"
            android:textAlignment="center"
            android:maxLines="2"
            android:textStyle="bold"
            android:fontFamily="@font/custom_font"
            android:text="Appointment Booked \n Successfully"
            android:textColor="@color/theme_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:textSize="14dp"
            android:padding="8dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/custom_font"
            android:textAlignment="textStart"
            android:background="@drawable/light_grey_bk"
            android:textColor="@color/black"
            android:id="@+id/descp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:textSize="15dp"
            android:textStyle="bold"
            android:layout_marginTop="15dp"
            android:textAlignment="textStart"
            android:fontFamily="@font/custom_font"
            android:text="You will get a confirmation message at your mobile number :"
            android:textColor="@color/black"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:textSize="14dp"
            android:padding="10dp"
            android:fontFamily="@font/custom_font"
            android:layout_gravity="start"
            android:layout_marginTop="10dp"
            android:textAlignment="center"
            android:background="@drawable/bluebt"
            android:id="@+id/mob"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:textSize="14dp"
            android:layout_marginTop="15dp"
            android:fontFamily="@font/custom_font"
            android:textAlignment="textStart"
            android:text="Please show this sms at clinic/hospital reception counter when you will visit at doctor's hospital/clinic. This sms is proof your appointment confirmation from Clinax. Thank You !"
            android:textColor="@color/theme_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:textSize="16dp"
            android:fontFamily="@font/custom_font"
            android:padding="10dp"
            android:layout_gravity="start"
            android:layout_marginTop="20dp"
            android:textAlignment="center"
            android:background="@drawable/green_back"
            android:text="Done"
            android:textStyle="bold"
            android:id="@+id/btdone"
            android:textColor="@color/white"
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

    </LinearLayout>
    </LinearLayout>