<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_margin="5dp"
    android:background="@drawable/lightgreybt"
    android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:background="@drawable/round_white_img"
            android:layout_width="60dp"
            android:padding="15dp"
            android:layout_margin="10dp"
            android:src="@drawable/doctor"
            android:layout_height="60dp"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_margin="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="16dp"
                android:fontFamily="@font/custom_font"
                android:textColor="@color/black"
                android:text="Dr. Ram Mishra"
                android:layout_marginLeft="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14dp"
                android:fontFamily="@font/custom_font"
                android:textColor="@color/black"
                android:text="( MBBS, MD )"
                android:layout_marginLeft="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="14dp"
                android:fontFamily="@font/custom_font"
                android:textColor="@color/black"
                android:text="Fee Rs. 400"
                android:layout_marginLeft="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/btconsult"
                android:textSize="13dp"
                android:fontFamily="@font/custom_font"
                android:textColor="@color/white"
                android:text="Online Consult"
                android:layout_margin="5dp"
                android:gravity="center"
                android:paddingLeft="18dp"
                android:textAlignment="center"
                android:paddingRight="18dp"
                android:paddingBottom="5dp"
                android:paddingTop="5dp"
                android:textStyle="bold"
                android:background="@drawable/bluebt"
                android:layout_width="wrap_content"
                android:layout_height="35dp"/>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>