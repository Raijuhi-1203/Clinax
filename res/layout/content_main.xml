<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:showIn="@layout/app_bar_main">

    <LinearLayout
        android:id="@+id/linear_layout"
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_marginBottom="0dp"
        android:background="@color/theme_2"
        android:weightSum="4"
        android:layout_height="90dp">

        <LinearLayout
            android:layout_margin="5dp"
            android:id="@+id/home_layout"
            android:layout_weight="1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imghome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:background="@drawable/roundgreybt"
                android:padding="10dp"
                android:src="@drawable/home" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="5dp"
                android:padding="5dp"
                android:text="Home"
                 android:fontFamily="@font/custom_font"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="10dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/white"/>

        <LinearLayout
            android:layout_margin="5dp"
            android:id="@+id/consult_layout"
            android:layout_weight="1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgconsult"
                android:background="@drawable/roundgreybt"
                android:padding="10dp"
                android:layout_gravity="center"
                android:layout_width="40dp"
                android:layout_marginTop="4dp"
                android:layout_height="40dp"
                android:src="@drawable/consult" />

            <TextView
                android:padding="5dp"
                android:layout_gravity="center"
                android:layout_marginTop="0dp"
                 android:fontFamily="@font/custom_font"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"
                android:textAlignment="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Consult Now"
                android:textColor="@color/white"
                android:textSize="10dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/white"/>

        <LinearLayout
            android:id="@+id/appoinment_layout"
            android:layout_weight="1"
            android:layout_margin="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgappointment"
                android:background="@drawable/roundgreybt"
                android:padding="10dp"
                android:layout_gravity="center"
                android:layout_width="40dp"
                android:layout_marginTop="4dp"
                android:layout_height="40dp"
                android:src="@drawable/appoinment" />

            <TextView
                android:padding="4dp"
                 android:fontFamily="@font/custom_font"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="5dp"
                android:textAlignment="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Appointment"
                android:textColor="@color/white"
                android:textSize="10dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/white"/>

        <LinearLayout
            android:id="@+id/help_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imghelp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="4dp"
                android:background="@drawable/roundgreybt"
                android:padding="10dp"
                android:src="@drawable/profile" />

            <TextView
                android:layout_width="match_parent"
                 android:fontFamily="@font/custom_font"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="5dp"
                android:padding="5dp"
                android:text="My Account"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="10dp" />

        </LinearLayout>

    </LinearLayout>

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/viewpager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="95dp"
        android:layout_marginBottom="5dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</RelativeLayout>