<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <include layout="@layout/header"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/bt_addcart">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:fontFamily="@font/custom_font"
                        android:textSize="14dp"
                        android:layout_margin="5dp"
                        android:text="Consult Online For Common Health Problems :-"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:orientation="vertical"
                        android:scrollbars="vertical"
                        android:id="@+id/rvproblem"
                        android:layout_marginTop="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />


                    <TextView
                        android:id="@+id/bt_consult_healthprblm"
                        android:textStyle="bold"
                        android:text="View More"
                        android:textAlignment="center"
                        android:textSize="14dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:fontFamily="@font/custom_font"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/white"
                        android:layout_marginRight="100dp"
                        android:layout_marginLeft="100dp"
                        android:background="@drawable/bluebt"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"/>

                    <TextView
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_margin="5dp"
                        android:fontFamily="@font/custom_font"
                        android:textSize="14dp"
                        android:text="Book Appoinment with Top Specialist :-"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvspeciality"
                        android:layout_marginTop="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/bt_view_spcilist"
                        android:textColor="@color/white"
                        android:layout_marginRight="100dp"
                        android:layout_marginLeft="100dp"
                        android:textStyle="bold"
                        android:fontFamily="@font/custom_font"
                        android:text="View All Specialist"
                        android:textAlignment="center"
                        android:textSize="14dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="40dp"
                        android:background="@drawable/bluebt"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"/>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>